// Prueba de entrada de datos en Iridium
out "--- SISTEMA DE ACCESO ---"

var nombre: string = await "Ingresa tu nombre: "
var edad: int = await "Ingresa tu edad: "

if edad >= 18:
    out "Bienvenido {nombre}, tienes acceso al servidor."
else:
    out "Lo siento {nombre}, el acceso requiere ser mayor de edad."
end